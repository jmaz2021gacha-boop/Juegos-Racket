#lang racket
(require 2htdp/universe
         2htdp/image
         rsound)

(define main-theme (rs-read "main-theme.wav"))
(define piggies-theme (rs-read "bad-piggies.wav"))
(require rsound)

(define musica (rs-read "main-theme.wav"))

(play musica)
;; Elementos gráficos
(define bird   (circle 15 "solid" "red"))
(define sling  (rectangle 20 60 "solid" "black"))
(define block  (rectangle 40 20 "solid" "brown"))
(define glass  (rectangle 40 20 "outline" "lightblue"))
(define pig    (rectangle 20 20 "solid" "green"))
(define ground (rectangle 1000 40 "solid" "green")) ; suelo más ancho

;; Botones
(define (boton texto)
  (overlay (text texto 20 "white")
           (rectangle 200 40 "solid" "blue")))

(define boton-menu    (boton "Menú de niveles"))
(define boton-restart (boton "Reiniciar nivel"))
(define boton-exit    (boton "Cerrar juego"))

(define-struct posn (x y))
(define-struct world (x y vx vy objs score birds-left angle power launched ready estado nivel))

;; Escenarios (niveles)
(define escenario1
  (list (list 'sling (make-posn 70 360))
        (list 'block (make-posn 400 340))
        (list 'glass (make-posn 440 340))
        (list 'pig   (make-posn 420 320))))

(define escenario2
  (list (list 'sling (make-posn 70 360))
        (list 'block (make-posn 500 340))
        (list 'glass (make-posn 540 340))
        (list 'pig   (make-posn 520 320))
        (list 'block (make-posn 560 340))
        (list 'glass (make-posn 600 340))
        (list 'pig   (make-posn 580 320))))
(define escenario3
  (list (list 'sling (make-posn 70 360))
        (list 'block (make-posn 500 340))
        (list 'block (make-posn 540 340))
        (list 'glass (make-posn 520 320))
        (list 'pig   (make-posn 520 280))))

;; Estado inicial del mundo
(define (nuevo-mundo nivel)

  (define escenario
    (cond
      [(= nivel 1) escenario1]
      [(= nivel 2) escenario2]
      [else escenario3]))

  (make-world
   0 0 0 0
   escenario
   0
   4
   45
   8
   #f
   #f
   "jugando"
   nivel))

(define initial-world (nuevo-mundo 1))

;; Colisiones
(define (colision? w obj)
  (and (member (first obj) '(pig block glass))
       (< (abs (- (world-x w) (posn-x (second obj)))) 20)
       (< (abs (- (world-y w) (posn-y (second obj)))) 20)))

(define (puntaje obj)
  (match (first obj)
    ['pig 1000]
    ['block 500]
    ['glass 300]
    [_ 0]))

;; Actualización física
(define (update w)
  (if (and (world-launched w) (equal? (world-estado w) "jugando"))
      (let* ([objetos-golpeados (filter (λ (obj) (colision? w obj)) (world-objs w))]
             [nuevos-objs (filter (λ (obj) (not (colision? w obj))) (world-objs w))]
             [nuevo-score (+ (world-score w) (apply + (map puntaje objetos-golpeados)))]
             [pigs-restantes (filter (λ (obj) (equal? (first obj) 'pig)) nuevos-objs)])
        (cond
          [(empty? pigs-restantes)
           (make-world
            (world-x w)
            (world-y w)
            (world-vx w)
            (world-vy w)
            nuevos-objs
            (+ nuevo-score (* (world-birds-left w) 10000))
            (world-birds-left w)
            (world-angle w)
            (world-power w)
            #f
            (world-ready w)
            "final"
            (world-nivel w))]
   
          [(and (< (world-y w) 0) (<= (world-birds-left w) 1)) ; derrota → pantalla final
           (make-world (world-x w) (world-y w) (world-vx w) (world-vy w)
                       nuevos-objs nuevo-score 0
                       (world-angle w) (world-power w) #f (world-ready w) "final" (world-nivel w))]
          [(and (< (world-y w) 0) (> (world-birds-left w) 1)) ; siguiente pájaro
           (make-world 0 0 0 0 nuevos-objs nuevo-score (- (world-birds-left w) 1)
                       45 8 #f #f "jugando" (world-nivel w))]
          [else ; movimiento normal
           (make-world (+ (world-x w) (world-vx w))
                       (+ (world-y w) (world-vy w))
                       (world-vx w)
                       (+ (world-vy w) 1)
                       nuevos-objs nuevo-score (world-birds-left w)
                       (world-angle w) (world-power w) #t (world-ready w) "jugando" (world-nivel w))]))
      w))


;; Control con teclado
(define (control w key)
  (cond
    [(and (key=? key "c") (equal? (world-estado w) "jugando"))
     (make-world 70 330 0 0 (world-objs w) (world-score w) (world-birds-left w)
                 (world-angle w) (world-power w) #f #t "jugando" (world-nivel w))]
    [(key=? key "up")   (make-world (world-x w) (world-y w) (world-vx w) (world-vy w)
                                    (world-objs w) (world-score w) (world-birds-left w)
                                    (+ (world-angle w) 5) (world-power w) (world-launched w) (world-ready w) (world-estado w) (world-nivel w))]
    [(key=? key "down") (make-world (world-x w) (world-y w) (world-vx w) (world-vy w)
                                    (world-objs w) (world-score w) (world-birds-left w)
                                    (- (world-angle w) 5) (world-power w) (world-launched w) (world-ready w) (world-estado w) (world-nivel w))]
    [(key=? key "right")(make-world (world-x w) (world-y w) (world-vx w) (world-vy w)
                                    (world-objs w) (world-score w) (world-birds-left w)
                                    (world-angle w) (+ (world-power w) 1) (world-launched w) (world-ready w) (world-estado w) (world-nivel w))]
    [(key=? key "left") (make-world (world-x w) (world-y w) (world-vx w) (world-vy w)
                                    (world-objs w) (world-score w) (world-birds-left w)
                                    (world-angle w) (max 1 (- (world-power w) 1)) (world-launched w) (world-ready w) (world-estado w) (world-nivel w))]
    [(and (key=? key " ") (world-ready w) (equal? (world-estado w) "jugando"))
     (make-world (world-x w) (world-y w)
                 (* (world-power w) (cos (/ (* pi (world-angle w)) 180)))
                 (* (world-power w) (- (sin (/ (* pi (world-angle w)) 180))))
                 (world-objs w) (world-score w) (world-birds-left w)
                 (world-angle w) (world-power w) #t (world-ready w) "jugando" (world-nivel w))]
    [else w]))

;; Manejo de clics en pantalla final
(define (mouse w x y event)

  (if (string=? event "button-down")

      (cond

        ;; =========================
        ;; BOTONES PANTALLA FINAL
        ;; =========================

        [(and (equal? (world-estado w) "final")

              (> x 345) (< x 415)
              (> y 295) (< y 365))

         ;; abrir menú
         (make-world
          (world-x w)
          (world-y w)
          (world-vx w)
          (world-vy w)
          (world-objs w)
          (world-score w)
          (world-birds-left w)
          (world-angle w)
          (world-power w)
          #f
          #f
          "menu"
          (world-nivel w))]

        [(and (equal? (world-estado w) "final")

              (> x 465) (< x 535)
              (> y 295) (< y 365))

         ;; reiniciar
         (nuevo-mundo (world-nivel w))]

        [(and (equal? (world-estado w) "final")

              (> x 585) (< x 655)
              (> y 295) (< y 365))

         ;; siguiente nivel
         (nuevo-mundo (+ 1 (world-nivel w)))]

        ;; =========================
        ;; MENU DE NIVELES
        ;; =========================

        [(and (equal? (world-estado w) "menu")
              (> x 260) (< x 340)
              (> y 160) (< y 240))

         (nuevo-mundo 1)]

        [(and (equal? (world-estado w) "menu")
              (> x 460) (< x 540)
              (> y 160) (< y 240))

         (nuevo-mundo 2)]

        [(and (equal? (world-estado w) "menu")
              (> x 660) (< x 740)
              (> y 160) (< y 240))

         (nuevo-mundo 3)]

        [else w])

      w))

;; Dibujo de objetos
(define (dibujar-objeto obj escena)
  (match obj
    [(list 'sling p) (place-image sling (posn-x p) (posn-y p) escena)]
    [(list 'block p) (place-image block (posn-x p) (posn-y p) escena)]
    [(list 'glass p) (place-image glass (posn-x p) (posn-y p) escena)]
    [(list 'pig p)   (place-image pig   (posn-x p) (posn-y p) escena)]))

;; Previsualización de trayectoria (línea roja punteada)
(define (trayectoria w escena)
  (if (and (world-ready w) (not (world-launched w)))
      (let loop ([x (world-x w)] [y (world-y w)]
                                 [vx (* (world-power w) (cos (/ (* pi (world-angle w)) 180)))]
                                 [vy (* (world-power w) (- (sin (/ (* pi (world-angle w)) 180))))]
                                 [esc escena] [steps 30])
        (if (zero? steps)
            esc
            (loop (+ x vx) (+ y vy) vx (+ vy 1)
                  (place-image (circle 2 "outline" "red") x y esc)
                  (- steps 1))))
      escena))
;;




(define (boton-circular color txt)
  (overlay
   (text txt 16 "white")
   (circle 35 "solid" color)))

(define boton-levels
  (boton-circular "blue" "MENU"))

(define boton-restart2
  (boton-circular "gray" "RESET"))

(define boton-next
  (boton-circular "gold" "NEXT"))
;; Dibujo completo
(define (draw w)
  (cond
    [(equal? (world-estado w) "jugando")
     (define escena-base (foldl dibujar-objeto (empty-scene 1000 400) (world-objs w)))
     (define escena-con-ground (place-image ground 500 380 escena-base))
     (define escena-con-bird
       (if (world-ready w)
           (place-image bird (world-x w) (world-y w) escena-con-ground)
           escena-con-ground))
     (define escena-con-trayectoria (trayectoria w escena-con-bird))
     (define escena-con-score (place-image (text (string-append "Score: " (number->string (world-score w))) 20 "black")
                                           900 30 escena-con-trayectoria))
     (define escena-con-birds (place-image (text (string-append "Birds left: " (number->string (world-birds-left w))) 20 "black")
                                           100 30 escena-con-score))
     (place-image (text (string-append "Angle: " (number->string (world-angle w)) "°  Power: " (number->string (world-power w))) 15 "blue")
                  500 370 escena-con-birds)]
    
 [(equal? (world-estado w) "final")

 (define fondo
   (place-image
    (rectangle 320 420 "solid" "black")
    500 200
    (empty-scene 1000 400)))

 (define escena1
   (place-image
    (text "LEVEL CLEARED!" 35 "white")
    500 50
    fondo))

 (define estrella
   (star 40 "solid" "yellow"))

 (define escena2
   (place-image estrella 400 130
    (place-image estrella 500 100
     (place-image estrella 600 130
      escena1))))

 (define escena3
   (place-image
    (text
     (number->string (world-score w))
     40
     "white")
    500 220
    escena2))

 (place-image boton-next 620 330
  (place-image boton-restart2 500 330
   (place-image boton-levels 380 330
    escena3)))]

 [(equal? (world-estado w) "menu")

 (define fondo
   (empty-scene 1000 400))

 (define titulo
   (place-image
    (text "SELECT LEVEL" 40 "blue")
    500 50
    fondo))

 (define (nivel-boton n x y escena)
  (place-image
   (overlay
    (text (number->string n) 25 "white")
    (rectangle 80 80 "solid" "darkblue"))
   x y
   escena))
 
 (nivel-boton 3 700 200
  (nivel-boton 2 500 200
   (nivel-boton 1 300 200
    titulo)))]

 ))

;; Ejecutar simulación
(big-bang initial-world
  [on-tick update]
  [to-draw draw]
  [on-key control]
  [on-mouse mouse])
